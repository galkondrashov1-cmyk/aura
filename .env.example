# Copy to .env and fill in. Production sets these in Vercel → Settings → Env Vars.

# Postgres (local: Docker/local postgres. prod: Vercel Postgres / Neon).
DATABASE_URL="postgresql://postgres:password@localhost:5432/hila"

# JWT signing secret — any long random string. Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
