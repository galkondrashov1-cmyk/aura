# Copy to .env and fill in. Production sets these in Vercel → Settings → Env Vars.

# Postgres (local: a dev branch / Neon / Docker postgres. prod: Vercel Postgres).
# Vercel Postgres injects both of these automatically when you create the store.
DATABASE_URL="postgresql://postgres:password@localhost:5432/aura"
DIRECT_URL="postgresql://postgres:password@localhost:5432/aura"

# JWT signing secret — any long random string. Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Image uploads. Local can use the filesystem via UPLOAD_DIR; prod uses Vercel Blob.
BLOB_READ_WRITE_TOKEN=""
UPLOAD_DIR="./public/uploads"

# ── PayPal subscriptions (payments stay OFF until ALL of these exist) ──
# Create a REST app at developer.paypal.com → copy Client ID + Secret yourself.
# Run scripts/paypal-setup.mjs (see file header) to create the billing plans.
PAYPAL_ENV="live"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
NEXT_PUBLIC_PAYPAL_PLAN_PLUS_MONTHLY=""
NEXT_PUBLIC_PAYPAL_PLAN_PLUS_YEARLY=""
NEXT_PUBLIC_PAYPAL_PLAN_PRO_MONTHLY=""
NEXT_PUBLIC_PAYPAL_PLAN_PRO_YEARLY=""
